{
  "name": "playwright-fintech-tests",
  "version": "1.0.0",
  "description": "QA automation system for Fintech Wallet – Playwright, Newman, k6, Qase, CI/CD",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:prod-smoke": "npx playwright test --grep @prod-smoke",
    "test:api": "npx playwright test tests/api/",
    "test:ui": "npx playwright test tests/ui/",
    "test:e2e": "npx playwright test tests/e2e/",
    "server": "npx ts-node server/server.ts",
    "report": "npx playwright show-report",
    "newman": "npx newman run postman/fintech-collection.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "dotenv": "^17.4.2",
    "newman": "^6.2.2",
    "playwright-qase-reporter": "^2.5.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2"
  }
}
